    "react-pdf": "^10.4.1",
    "resend": "^6.12.2",
    "zustand": "^5.0.12"
  },
  "devDependencies": {
    "@opennextjs/cloudflare": "^1.19.4",
    "@tailwindcss/postcss": "^4",
    "dotenv": "^17.4.2",
